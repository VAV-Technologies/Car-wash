# Supabase Backup System Configuration
# Copy this to config.env and fill in your values

# Database Connection (get from Supabase Dashboard > Settings > Database)
# Use the connection string from "Connection Pooling" section with mode "Session"
DB_CONNECTION_STRING="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# Alternative: Individual connection parameters
DB_HOST="aws-0-us-east-1.pooler.supabase.com"
DB_PORT="6543"
DB_NAME="postgres"
DB_USER="postgres.[PROJECT-REF]"
DB_PASSWORD="your-db-password"

# Supabase Project Details
SUPABASE_PROJECT_REF="kktmizfxgtkodtujursv"
SUPABASE_URL="https://kktmizfxgtkodtujursv.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"

# Storage Buckets to Backup
STORAGE_BUCKETS=(
    "listing-images"
    "listing-documents" 
    "onboarding-documents"
)

# Backup Settings
BACKUP_DIR="$HOME/supabase-backups"
BACKUP_RETENTION_DAYS=30
COMPRESS_BACKUPS=true
VERIFY_AFTER_BACKUP=true

# Notification Settings (optional)
NOTIFY_EMAIL=""
NOTIFY_SLACK_WEBHOOK=""

# Performance Settings
PARALLEL_DOWNLOADS=5
CHUNK_SIZE_MB=10

# Safety Settings
REQUIRE_CONFIRMATION=true
CREATE_PRE_RESTORE_BACKUP=true